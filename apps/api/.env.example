# ── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
# Pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# Enable when behind a reverse proxy (nginx, Caddy, Cloudflare) so the
# real client IP is read from X-Forwarded-For for rate limiting & logs.
TRUST_PROXY=false

# ── Auth ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_long_random_string
JWT_ACCESS_EXPIRES_IN=1d

# ── Encryption ─────────────────────────────────────────
# Used to encrypt at-rest secrets like GA service account JSONs.
# Generate: openssl rand -hex 32  (any 32+ char string also works)
ENCRYPTION_KEY=change_me_long_random_string_min_32_chars

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://narah:narah@localhost:5432/narah_cms?schema=public

# ── Storage ────────────────────────────────────────────
# local | s3 | r2
#   local — filesystem (dev only)
#   s3    — any S3-compatible: Backblaze B2, MinIO, AWS S3, DO Spaces, Wasabi, R2
#   r2    — legacy alias for Cloudflare R2 (uses R2_* vars below)
STORAGE_DRIVER=local

# Local driver — files written under this directory (gitignored).
STORAGE_LOCAL_DIR=storage
# Base URL where uploaded files are served from.
# Leave unset to default to http://localhost:${PORT}/storage in dev.
# In prod behind a reverse proxy / CDN, set explicitly: https://cdn.example.com
# STORAGE_PUBLIC_BASE_URL=

# ── Generic S3 driver (STORAGE_DRIVER=s3) ─────────────
# Endpoint examples:
#   Backblaze B2 : https://s3.us-west-004.backblazeb2.com  (region = us-west-004)
#   AWS S3       : https://s3.ap-southeast-1.amazonaws.com (region = ap-southeast-1)
#   MinIO        : https://minio.example.com               (region = us-east-1, force-path-style = true)
#   DO Spaces    : https://sgp1.digitaloceanspaces.com     (region = sgp1)
# S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# S3_REGION=us-west-004
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=narah-dev
# Public URL pattern depends on provider (or custom CDN domain):
#   B2 friendly URL: https://f004.backblazeb2.com/file/<bucket>
#   Custom domain  : https://media.example.com
# S3_PUBLIC_BASE_URL=https://f004.backblazeb2.com/file/narah-dev
# Most modern providers support virtual-host style. MinIO usually needs path-style.
# S3_FORCE_PATH_STYLE=false

# ── Cloudflare R2 driver (STORAGE_DRIVER=r2) ──────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Public URL for the bucket (use your custom domain or the r2.dev URL).
# R2_PUBLIC_BASE_URL=https://media.example.com

# Upload limit (MB) — applies to all storage drivers
MAX_UPLOAD_SIZE_MB=10

# ── Image transform ────────────────────────────────────
# Where transformed image variants are cached on disk (gitignored).
IMAGE_CACHE_DIR=.cache/images
# Base URL for the API itself — used to build public asset.url values.
# Leave unset to default to http://localhost:${PORT} in dev.
# API_PUBLIC_BASE_URL=https://api.example.com
